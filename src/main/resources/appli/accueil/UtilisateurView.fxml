<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="650.0" prefWidth="950.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="appli.accueil.UtilisateurController">

    <top>
        <VBox style="-fx-background-color: #e67e22; -fx-padding: 20;">
            <HBox alignment="CENTER_LEFT" spacing="15.0">
                <Button text="← Retour" onAction="#handleRetour"
                        style="-fx-background-color: #d35400; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" />
                <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                    <Label text="Gestion des Utilisateurs" textFill="WHITE">
                        <font><Font name="Arial Bold" size="24.0" /></font>
                    </Label>
                    <Label text="Consulter, modifier et supprimer les comptes utilisateurs" textFill="#ecf0f1">
                        <font><Font name="Arial" size="12.0" /></font>
                    </Label>
                </VBox>
            </HBox>
        </VBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.32">

            <!-- Formulaire modification -->
            <VBox spacing="12.0" style="-fx-background-color: #ecf0f1;">
                <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>

                <Label text="Modifier un utilisateur" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
                <Label text="Sélectionnez un utilisateur dans la liste pour le modifier."
                       style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d;" wrapText="true" />

                <VBox spacing="4.0">
                    <Label text="Nom" />
                    <TextField fx:id="nomTextField" promptText="Nom" />
                </VBox>
                <VBox spacing="4.0">
                    <Label text="Prénom" />
                    <TextField fx:id="prenomTextField" promptText="Prénom" />
                </VBox>
                <VBox spacing="4.0">
                    <Label text="Email" />
                    <TextField fx:id="emailTextField" promptText="email@exemple.fr" />
                </VBox>
                <VBox spacing="4.0">
                    <Label text="Rôle" />
                    <ComboBox fx:id="roleCombo" maxWidth="Infinity" />
                </VBox>

                <VBox fx:id="mdpBox" spacing="4.0" visible="false" managed="false">
                    <Label text="Nouveau mot de passe" style="-fx-text-fill: #8e44ad; -fx-font-weight: bold;" />
                    <PasswordField fx:id="mdpField" promptText="Laisser vide pour ne pas modifier" />
                    <PasswordField fx:id="mdpConfirmField" promptText="Confirmer le mot de passe" />
                </VBox>

                <Label fx:id="messageLabel" wrapText="true">
                    <font><Font name="Arial Bold" size="11.0" /></font>
                </Label>

                <HBox spacing="8.0">
                    <Button fx:id="ajouterBtn" text="(Inscription)" disable="true"
                            style="-fx-background-color: #bdc3c7; -fx-text-fill: white;" prefWidth="100.0" />
                    <Button fx:id="modifierBtn" text="Modifier" onAction="#handleModifier"
                            style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold;" prefWidth="90.0" disable="true" />
                    <Button fx:id="annulerBtn" text="Annuler" onAction="#handleAnnuler"
                            style="-fx-background-color: #95a5a6; -fx-text-fill: white;" prefWidth="80.0" />
                </HBox>

                <Separator />
                <Label text="Rechercher" style="-fx-font-weight: bold;" />
                <TextField fx:id="rechercheTextField" promptText="Nom, prénom ou email..." onKeyReleased="#handleRecherche" />

                <Separator />
                <Label style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d; -fx-wrap-text: true;"
                       text="Pour créer un compte, utilisez la page d'inscription depuis l'écran de connexion." />
            </VBox>

            <!-- Table -->
            <VBox spacing="10.0">
                <padding><Insets bottom="20.0" left="10.0" right="20.0" top="20.0" /></padding>

                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <Label text="Liste des utilisateurs" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
                    <Label fx:id="compteurLabel" text="(0 utilisateur)" style="-fx-text-fill: #7f8c8d;" />
                </HBox>

                <TableView fx:id="utilisateurTableView" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="idColumn" text="ID" prefWidth="45.0" />
                        <TableColumn fx:id="nomColumn" text="Nom" prefWidth="120.0" />
                        <TableColumn fx:id="prenomColumn" text="Prénom" prefWidth="120.0" />
                        <TableColumn fx:id="emailColumn" text="Email" prefWidth="180.0" />
                        <TableColumn fx:id="roleColumn" text="Rôle" prefWidth="140.0" />
                        <TableColumn fx:id="actionsColumn" text="Actions" prefWidth="90.0" />
                    </columns>
                </TableView>

                <HBox spacing="10.0" alignment="CENTER_RIGHT">
                    <Button text="Actualiser" onAction="#handleActualiser"
                            style="-fx-background-color: #3498db; -fx-text-fill: white;" />
                    <Button fx:id="supprimerBtn" text="Supprimer" onAction="#handleSupprimer"
                            style="-fx-background-color: #e74c3c; -fx-text-fill: white;" disable="true" />
                </HBox>
            </VBox>

        </SplitPane>
    </center>

    <bottom>
        <HBox alignment="CENTER" style="-fx-background-color: #34495e; -fx-padding: 10;">
            <Label fx:id="statutLabel" text="Prêt" textFill="WHITE">
                <font><Font name="Arial" size="11.0" /></font>
            </Label>
        </HBox>
    </bottom>

</BorderPane>
