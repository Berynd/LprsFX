<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="1200.0" prefWidth="1000.0" style="-fx-background-color: linear-gradient(to bottom right, #1a1a2e, #16213e, #0f3460);" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="appli.accueil.AccueilController">
    
    <!-- Barre de navigation en haut -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: rgba(255, 255, 255, 0.05); -fx-padding: 15 30; -fx-border-color: rgba(255, 255, 255, 0.1); -fx-border-width: 0 0 1 0;">
            <Label style="-fx-font-weight: bold; -fx-font-size: 20px; -fx-font-family: 'Segoe UI Semibold';" text="LPRS Manager" textFill="#00d4ff" />
            
            <Region HBox.hgrow="ALWAYS" />
            
            <Label fx:id="utilisateurLabel" style="-fx-font-size: 12px;" text="👤 Connecté en tant que..." textFill="WHITE">
                <font>
                    <Font name="Arial" size="12.0" />
                </font>
            </Label>
            
            <Button onAction="#handleDeconnexion" style="-fx-background-color: rgba(231, 76, 60, 0.2); -fx-text-fill: #e74c3c; -fx-border-color: #e74c3c; -fx-border-width: 1; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8 15; -fx-font-weight: bold; -fx-cursor: hand;" text="Se déconnecter" />
        </HBox>
    </top>
    
    <!-- Contenu central -->
    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" prefHeight="610.0" prefWidth="1000.0" style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;" vbarPolicy="AS_NEEDED">
        <VBox alignment="TOP_CENTER" spacing="40.0" style="-fx-padding: 50;">
            
            <!-- En-tête de bienvenue -->
            <VBox alignment="CENTER" spacing="1.0">
                <Label style="-fx-font-size: 42px; -fx-font-weight: bold; -fx-font-family: 'Segoe UI Light';" text="Bienvenue sur LPRS Manager" textFill="WHITE">
                    <effect>
                        <DropShadow color="#00d4ff" radius="10" spread="0.3" />
                    </effect>
                </Label>
                <Label style="-fx-font-size: 16px; -fx-font-family: 'Segoe UI';" text="Votre système de gestion tout-en-un" textFill="#95a5a6" />
            </VBox>
            
            <!-- Grille de cartes de menu (3 colonnes × 4 lignes) -->
            <!-- Ligne 0 : Salles | Fournisseurs | Fournitures              -->
            <!-- Ligne 1 : Utilisateurs | Demandes | Rendez-vous            -->
            <!-- Ligne 2 : Fiches étudiantes | Dossiers | Filières          -->
            <!-- Ligne 3 : Espace Secrétaire | Espace Professeur | Espace Gestionnaire -->
            <GridPane alignment="CENTER" hgap="25.0" vgap="25.0">

                <!-- Ligne 0 -->
                <VBox fx:id="carteSalles" alignment="CENTER" onMouseClicked="#handleGestionSalles" prefHeight="200.0" prefWidth="220.0" spacing="15.0" style="-fx-background-color: rgba(255, 255, 255, 0.08); -fx-background-radius: 15; -fx-padding: 30; -fx-border-color: rgba(255, 255, 255, 0.3); -fx-border-width: 1; -fx-border-radius: 15; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.3), 15, 0, 0, 5);" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <Label style="-fx-font-size: 48px;" text="🏢" />
                    <Label style="-fx-font-size: 16px; -fx-font-weight: bold;" text="Gestion des Salles" textFill="WHITE" />
                    <Label style="-fx-font-size: 11px; -fx-text-alignment: center;" text="Gérer les salles de cours" textFill="#95a5a6" wrapText="true" />
                </VBox>
                <VBox fx:id="carteFournisseurs" alignment="CENTER" onMouseClicked="#handleGestionFournisseurs" prefHeight="200.0" prefWidth="220.0" spacing="15.0" style="-fx-background-color: rgba(255, 255, 255, 0.08); -fx-background-radius: 15; -fx-padding: 30; -fx-border-color: rgba(0, 255, 0, 0.3); -fx-border-width: 1; -fx-border-radius: 15; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.3), 15, 0, 0, 5);" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <Label style="-fx-font-size: 48px;" text="📦" />
                    <Label style="-fx-font-size: 16px; -fx-font-weight: bold;" text="Fournisseurs" textFill="WHITE" />
                    <Label style="-fx-font-size: 11px; -fx-text-alignment: center;" text="Gérer vos fournisseurs" textFill="#95a5a6" wrapText="true" />
                </VBox>

                <!-- Carte Gestion des Fournitures -->
                <VBox fx:id="carteFournitures" alignment="CENTER" onMouseClicked="#handleGestionFournitures" prefHeight="200.0" prefWidth="220.0" spacing="15.0" style="-fx-background-color: rgba(255, 255, 255, 0.08); -fx-background-radius: 15; -fx-padding: 30; -fx-border-color: rgba(0, 255, 255, 0.3); -fx-border-width: 1; -fx-border-radius: 15; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.3), 15, 0, 0, 5);" GridPane.columnIndex="2" GridPane.rowIndex="0">
                    <Label style="-fx-font-size: 48px;" text="📋" />
                    <Label style="-fx-font-size: 16px; -fx-font-weight: bold;" text="Fournitures" textFill="WHITE" />
                    <Label style="-fx-font-size: 11px; -fx-text-alignment: center;" text="Stock et fournitures" textFill="#95a5a6" wrapText="true" />
                </VBox>

                <!-- Ligne 1 -->
                <VBox fx:id="carteUtilisateurs" alignment="CENTER" onMouseClicked="#handleGestionUtilisateurs" prefHeight="200.0" prefWidth="220.0" spacing="15.0" style="-fx-background-color: rgba(255, 255, 255, 0.08); -fx-background-radius: 15; -fx-padding: 30; -fx-border-color: rgba(255, 255, 255, 0.3); -fx-border-width: 1; -fx-border-radius: 15; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.3), 15, 0, 0, 5);" GridPane.columnIndex="0" GridPane.rowIndex="1">
                    <Label style="-fx-font-size: 48px;" text="👥" />
                    <Label style="-fx-font-size: 16px; -fx-font-weight: bold;" text="Utilisateurs" textFill="WHITE" />
                    <Label style="-fx-font-size: 11px; -fx-text-alignment: center;" text="Gérer les comptes" textFill="#95a5a6" wrapText="true" />
                </VBox>
                <VBox fx:id="carteDemandes" alignment="CENTER" onMouseClicked="#handleDemandes" prefHeight="200.0" prefWidth="220.0" spacing="15.0" style="-fx-background-color: rgba(255, 255, 255, 0.08); -fx-background-radius: 15; -fx-padding: 30; -fx-border-color: rgba(0, 255, 255, 0.3); -fx-border-width: 1; -fx-border-radius: 15; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.3), 15, 0, 0, 5);" GridPane.columnIndex="1" GridPane.rowIndex="1">
                    <Label style="-fx-font-size: 48px;" text="📝" />
                    <Label style="-fx-font-size: 16px; -fx-font-weight: bold;" text="Demandes" textFill="WHITE" />
                    <Label style="-fx-font-size: 11px; -fx-text-alignment: center;" text="Demandes de fournitures" textFill="#95a5a6" wrapText="true" />
                </VBox>
                <VBox fx:id="carteRendezVous" alignment="CENTER" onMouseClicked="#handleRendezVous" prefHeight="200.0" prefWidth="220.0" spacing="15.0" style="-fx-background-color: rgba(255, 255, 255, 0.08); -fx-background-radius: 15; -fx-padding: 30; -fx-border-color: rgba(0, 0, 255, 0.3); -fx-border-width: 1; -fx-border-radius: 15; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.3), 15, 0, 0, 5);" GridPane.columnIndex="2" GridPane.rowIndex="1">
                    <Label style="-fx-font-size: 48px;" text="📅" />
                    <Label style="-fx-font-size: 16px; -fx-font-weight: bold;" text="Rendez-vous" textFill="WHITE" />
                    <Label style="-fx-font-size: 11px; -fx-text-alignment: center;" text="Planifier des RDV" textFill="#95a5a6" wrapText="true" />
                </VBox>

                <!-- Ligne 2 -->
                <VBox fx:id="carteFicheEtudiante" alignment="CENTER" onMouseClicked="#handleFicheEtudiante" prefHeight="200.0" prefWidth="220.0" spacing="15.0" style="-fx-background-color: rgba(255, 255, 255, 0.08); -fx-background-radius: 15; -fx-padding: 30; -fx-border-color: rgba(255, 0, 0, 0.3); -fx-border-width: 1; -fx-border-radius: 15; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.3), 15, 0, 0, 5);" GridPane.columnIndex="0" GridPane.rowIndex="2">
                    <Label style="-fx-font-size: 48px;" text="🎓" />
                    <Label style="-fx-font-size: 16px; -fx-font-weight: bold;" text="Fiches Étudiantes" textFill="WHITE" />
                    <Label style="-fx-font-size: 11px; -fx-text-alignment: center;" text="Gérer les fiches étudiantes" textFill="#95a5a6" wrapText="true" />
                </VBox>
                <VBox fx:id="carteDossiers" alignment="CENTER" onMouseClicked="#handleDossiers" prefHeight="200.0" prefWidth="220.0" spacing="15.0" style="-fx-background-color: rgba(255, 255, 255, 0.08); -fx-background-radius: 15; -fx-padding: 30; -fx-border-color: rgba(255, 0, 0, 0.3); -fx-border-width: 1; -fx-border-radius: 15; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.3), 15, 0, 0, 5);" GridPane.columnIndex="1" GridPane.rowIndex="2">
                    <Label style="-fx-font-size: 48px;" text="📄" />
                    <Label style="-fx-font-size: 16px; -fx-font-weight: bold;" text="Dossiers Inscription" textFill="WHITE" />
                    <Label style="-fx-font-size: 11px; -fx-text-alignment: center;" text="Suivi des dossiers d'inscription" textFill="#95a5a6" wrapText="true" />
                </VBox>
                <VBox fx:id="carteFilieres" alignment="CENTER" onMouseClicked="#handleFilieres" prefHeight="200.0" prefWidth="220.0" spacing="15.0" style="-fx-background-color: rgba(255, 255, 255, 0.08); -fx-background-radius: 15; -fx-padding: 30; -fx-border-color: rgba(255, 0, 0, 0.3); -fx-border-width: 1; -fx-border-radius: 15; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.3), 15, 0, 0, 5);" GridPane.columnIndex="2" GridPane.rowIndex="2">
                    <Label style="-fx-font-size: 48px;" text="📚" />
                    <Label style="-fx-font-size: 16px; -fx-font-weight: bold;" text="Filière" textFill="WHITE" />
                    <Label style="-fx-font-size: 11px; -fx-text-alignment: center;" text="Gestion des filières" textFill="#95a5a6" wrapText="true" />
                </VBox>

                <!-- Ligne 3 : Espaces dédiés par rôle -->
                <VBox fx:id="carteEspaceSecretaire" alignment="CENTER" onMouseClicked="#handleEspaceSecretaire" prefHeight="200.0" prefWidth="220.0" spacing="15.0" style="-fx-background-color: rgba(255, 255, 255, 0.08); -fx-background-radius: 15; -fx-padding: 30; -fx-border-color: rgba(255, 0, 0, 0.3); -fx-border-width: 1; -fx-border-radius: 15; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.3), 15, 0, 0, 5);" GridPane.columnIndex="0" GridPane.rowIndex="3">
                    <Label style="-fx-font-size: 48px;" text="🏫" />
                    <Label style="-fx-font-size: 16px; -fx-font-weight: bold;" text="Espace Secrétaire" textFill="WHITE" />
                    <Label style="-fx-font-size: 11px; -fx-text-alignment: center;" text="Tableau de bord secrétaire" textFill="#95a5a6" wrapText="true" />
                </VBox>
                <VBox fx:id="carteEspaceProfesseur" alignment="CENTER" onMouseClicked="#handleEspaceProfesseur" prefHeight="200.0" prefWidth="220.0" spacing="15.0" style="-fx-background-color: rgba(255, 255, 255, 0.08); -fx-background-radius: 15; -fx-padding: 30; -fx-border-color: rgba(0, 0, 255, 0.3); -fx-border-width: 1; -fx-border-radius: 15; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.3), 15, 0, 0, 5);" GridPane.columnIndex="1" GridPane.rowIndex="3">
                    <Label style="-fx-font-size: 48px;" text="👨‍🏫" />
                    <Label style="-fx-font-size: 16px; -fx-font-weight: bold;" text="Espace Professeur" textFill="WHITE" />
                    <Label style="-fx-font-size: 11px; -fx-text-alignment: center;" text="Tableau de bord professeur" textFill="#95a5a6" wrapText="true" />
                </VBox>
                <VBox fx:id="carteEspaceGestionnaire" alignment="CENTER" onMouseClicked="#handleEspaceGestionnaire" prefHeight="200.0" prefWidth="220.0" spacing="15.0" style="-fx-background-color: rgba(255, 255, 255, 0.08); -fx-background-radius: 15; -fx-padding: 30; -fx-border-color: rgba(0, 255, 0, 0.3); -fx-border-width: 1; -fx-border-radius: 15; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.3), 15, 0, 0, 5);" GridPane.columnIndex="2" GridPane.rowIndex="3">
                    <Label style="-fx-font-size: 48px;" text="📦" />
                    <Label style="-fx-font-size: 16px; -fx-font-weight: bold;" text="Espace Gestionnaire" textFill="WHITE" />
                    <Label style="-fx-font-size: 11px; -fx-text-alignment: center;" text="Tableau de bord stock" textFill="#95a5a6" wrapText="true" />
                </VBox>

            <columnConstraints>
               <ColumnConstraints />
               <ColumnConstraints />
               <ColumnConstraints />
            </columnConstraints>
            <rowConstraints>
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
            </rowConstraints>

            </GridPane>
            
        </VBox>
        </ScrollPane>
    </center>
    
    <!-- Pied de page -->
    <bottom>
        <HBox alignment="CENTER" spacing="30.0" style="-fx-background-color: rgba(0, 0, 0, 0.3); -fx-padding: 20; -fx-border-color: rgba(255, 255, 255, 0.1); -fx-border-width: 1 0 0 0;">
            <VBox alignment="CENTER" spacing="5.0">
                <Label style="-fx-font-size: 10px;" text="Version 1.0.0" textFill="#7f8c8d" />
                <Label style="-fx-font-size: 10px;" text="© 2026 LPRS - Tous droits réservés" textFill="#7f8c8d" />
            </VBox>
            
            <Region HBox.hgrow="ALWAYS" />
            
            <Label fx:id="dateHeureLabel" style="-fx-font-size: 11px;" text="📅 Lundi 02 février 2026 - 14:30" textFill="#95a5a6" />
        </HBox>
    </bottom>
    
</BorderPane>
