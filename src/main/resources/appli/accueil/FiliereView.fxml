<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="550.0" prefWidth="750.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="appli.accueil.FiliereController">

    <top>
        <VBox style="-fx-background-color: #27ae60; -fx-padding: 20;">
            <HBox alignment="CENTER_LEFT" spacing="15.0">
                <Button text="← Retour" onAction="#handleRetour"
                        style="-fx-background-color: #1e8449; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" />
                <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                    <Label text="Gestion des Filières" textFill="WHITE">
                        <font><Font name="Arial Bold" size="24.0" /></font>
                    </Label>
                    <Label text="Ajouter, modifier et supprimer les filières de formation" textFill="#ecf0f1">
                        <font><Font name="Arial" size="12.0" /></font>
                    </Label>
                </VBox>
            </HBox>
        </VBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.32">

            <!-- Formulaire -->
            <VBox spacing="12.0" style="-fx-background-color: #ecf0f1;">
                <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>

                <Label text="Informations de la filière" style="-fx-font-weight: bold; -fx-font-size: 14px;" />

                <VBox spacing="4.0">
                    <Label text="Nom de la filière *" />
                    <TextField fx:id="nomTextField" promptText="Ex: BTS SIO, Licence Pro..." />
                </VBox>

                <Label fx:id="messageLabel" wrapText="true">
                    <font><Font name="Arial Bold" size="11.0" /></font>
                </Label>

                <HBox spacing="8.0">
                    <Button fx:id="ajouterBtn" text="Ajouter" onAction="#handleAjouter"
                            style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;" prefWidth="90.0" />
                    <Button fx:id="modifierBtn" text="Modifier" onAction="#handleModifier"
                            style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold;" prefWidth="90.0" disable="true" />
                    <Button fx:id="annulerBtn" text="Annuler" onAction="#handleAnnuler"
                            style="-fx-background-color: #95a5a6; -fx-text-fill: white;" prefWidth="80.0" />
                </HBox>

                <Separator />
                <Label text="Rechercher" style="-fx-font-weight: bold;" />
                <TextField fx:id="rechercheTextField" promptText="Rechercher par nom..." onKeyReleased="#handleRecherche" />
            </VBox>

            <!-- Table -->
            <VBox spacing="10.0">
                <padding><Insets bottom="20.0" left="10.0" right="20.0" top="20.0" /></padding>

                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <Label text="Liste des filières" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
                    <Label fx:id="compteurLabel" text="(0 filière)" style="-fx-text-fill: #7f8c8d;" />
                </HBox>

                <TableView fx:id="filiereTableView" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="idColumn" text="ID" prefWidth="60.0" />
                        <TableColumn fx:id="nomColumn" text="Nom de la filière" prefWidth="350.0" />
                        <TableColumn fx:id="actionsColumn" text="Actions" prefWidth="120.0" />
                    </columns>
                </TableView>

                <HBox spacing="10.0" alignment="CENTER_RIGHT">
                    <Button text="Actualiser" onAction="#handleActualiser"
                            style="-fx-background-color: #3498db; -fx-text-fill: white;" />
                    <Button fx:id="supprimerBtn" text="Supprimer" onAction="#handleSupprimer"
                            style="-fx-background-color: #e74c3c; -fx-text-fill: white;" disable="true" />
                </HBox>
            </VBox>

        </SplitPane>
    </center>

    <bottom>
        <HBox alignment="CENTER" style="-fx-background-color: #34495e; -fx-padding: 10;">
            <Label fx:id="statutLabel" text="Prêt" textFill="WHITE">
                <font><Font name="Arial" size="11.0" /></font>
            </Label>
        </HBox>
    </bottom>

</BorderPane>
