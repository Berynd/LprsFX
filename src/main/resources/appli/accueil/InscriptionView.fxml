<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="750.0" prefWidth="950.0"
           style="-fx-background-color: linear-gradient(to bottom right, #1a1a2e, #16213e, #0f3460);"
           xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="appli.accueil.InscriptionController">

    <VBox alignment="TOP_CENTER" maxWidth="520.0" spacing="0.0"
          style="-fx-background-color: rgba(255, 255, 255, 0.06); -fx-background-radius: 20; -fx-border-color: rgba(0, 212, 255, 0.25); -fx-border-width: 1; -fx-border-radius: 20; -fx-padding: 45 50 45 50;">
        <effect>
            <DropShadow color="rgba(0, 0, 0, 0.5)" radius="30" spread="0.1" />
        </effect>

        <!-- En-tête -->
        <VBox alignment="CENTER" spacing="8.0" style="-fx-padding: 0 0 30 0;">
            <Label style="-fx-font-size: 40px;" text="✨" />
            <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-font-family: 'Segoe UI Semibold';"
                   text="Créer un compte" textFill="#00d4ff">
                <effect>
                    <DropShadow color="#00d4ff" radius="8" spread="0.2" />
                </effect>
            </Label>
            <Label style="-fx-font-size: 12px;" text="Rejoignez LPRS Manager" textFill="#95a5a6" />
        </VBox>

        <!-- Nom et Prénom -->
        <HBox spacing="15.0" style="-fx-padding: 0 0 18 0;">
            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-size: 12px; -fx-font-weight: bold;" text="Nom" textFill="#b0bec5" />
                <TextField fx:id="nomText" promptText="Votre nom"
                           style="-fx-background-color: rgba(255, 255, 255, 0.08); -fx-text-fill: white; -fx-prompt-text-fill: #546e7a; -fx-background-radius: 10; -fx-border-color: rgba(255, 255, 255, 0.15); -fx-border-radius: 10; -fx-padding: 11 13; -fx-font-size: 13px;" />
            </VBox>
            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-size: 12px; -fx-font-weight: bold;" text="Prénom" textFill="#b0bec5" />
                <TextField fx:id="prenomText" promptText="Votre prénom"
                           style="-fx-background-color: rgba(255, 255, 255, 0.08); -fx-text-fill: white; -fx-prompt-text-fill: #546e7a; -fx-background-radius: 10; -fx-border-color: rgba(255, 255, 255, 0.15); -fx-border-radius: 10; -fx-padding: 11 13; -fx-font-size: 13px;" />
            </VBox>
        </HBox>

        <!-- Email -->
        <VBox spacing="6.0" style="-fx-padding: 0 0 18 0;">
            <Label style="-fx-font-size: 12px; -fx-font-weight: bold;" text="Adresse email" textFill="#b0bec5" />
            <TextField fx:id="emailText" promptText="exemple@email.com"
                       style="-fx-background-color: rgba(255, 255, 255, 0.08); -fx-text-fill: white; -fx-prompt-text-fill: #546e7a; -fx-background-radius: 10; -fx-border-color: rgba(255, 255, 255, 0.15); -fx-border-radius: 10; -fx-padding: 11 13; -fx-font-size: 13px;" />
        </VBox>

        <!-- Mot de passe et confirmation -->
        <HBox spacing="15.0" style="-fx-padding: 0 0 18 0;">
            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-size: 12px; -fx-font-weight: bold;" text="Mot de passe" textFill="#b0bec5" />
                <PasswordField fx:id="mdpTexte" promptText="••••••••"
                               style="-fx-background-color: rgba(255, 255, 255, 0.08); -fx-text-fill: white; -fx-prompt-text-fill: #546e7a; -fx-background-radius: 10; -fx-border-color: rgba(255, 255, 255, 0.15); -fx-border-radius: 10; -fx-padding: 11 13; -fx-font-size: 13px;" />
            </VBox>
            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-size: 12px; -fx-font-weight: bold;" text="Confirmer" textFill="#b0bec5" />
                <PasswordField fx:id="mdpconfirmerTexte" promptText="••••••••"
                               style="-fx-background-color: rgba(255, 255, 255, 0.08); -fx-text-fill: white; -fx-prompt-text-fill: #546e7a; -fx-background-radius: 10; -fx-border-color: rgba(255, 255, 255, 0.15); -fx-border-radius: 10; -fx-padding: 11 13; -fx-font-size: 13px;" />
            </VBox>
        </HBox>

        <!-- Rôle -->
        <VBox spacing="6.0" style="-fx-padding: 0 0 20 0;">
            <Label style="-fx-font-size: 12px; -fx-font-weight: bold;" text="Rôle" textFill="#b0bec5" />
            <ComboBox fx:id="roleCombo" maxWidth="Infinity" promptText="Sélectionnez votre rôle"
                      style="-fx-background-color: rgba(255, 255, 255, 0.08); -fx-background-radius: 10; -fx-border-color: rgba(255, 255, 255, 0.15); -fx-border-radius: 10; -fx-padding: 3 5; -fx-font-size: 13px;" />
        </VBox>

        <!-- Message erreur/succès -->
        <Label fx:id="erreur" maxWidth="420.0"
               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 0 0 15 0;"
               text="" textFill="RED" wrapText="true" />

        <!-- Bouton Inscription -->
        <Button fx:id="inscription" maxWidth="Infinity" onAction="#onHelloButtonClickInscription"
                text="Créer mon compte"
                style="-fx-background-color: linear-gradient(to right, #00d4ff, #0099cc); -fx-text-fill: #1a1a2e; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 10; -fx-padding: 13 0; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0, 212, 255, 0.4), 15, 0, 0, 3);" />

        <!-- Séparateur -->
        <HBox alignment="CENTER" spacing="10.0" style="-fx-padding: 20 0 15 0;">
            <Region HBox.hgrow="ALWAYS" style="-fx-background-color: rgba(255, 255, 255, 0.15); -fx-pref-height: 1;" />
            <Label style="-fx-font-size: 11px;" text="ou" textFill="#546e7a" />
            <Region HBox.hgrow="ALWAYS" style="-fx-background-color: rgba(255, 255, 255, 0.15); -fx-pref-height: 1;" />
        </HBox>

        <!-- Lien Connexion -->
        <HBox alignment="CENTER" spacing="5.0">
            <Label style="-fx-font-size: 12px;" text="Déjà un compte ?" textFill="#95a5a6" />
            <Button fx:id="connexion" onAction="#onHelloButtonClickConnexion" text="Se connecter"
                    style="-fx-background-color: transparent; -fx-text-fill: #00d4ff; -fx-font-weight: bold; -fx-font-size: 12px; -fx-cursor: hand; -fx-padding: 0; -fx-underline: true;" />
        </HBox>
    </VBox>

</StackPane>
