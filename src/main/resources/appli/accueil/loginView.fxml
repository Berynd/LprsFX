<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="650.0" prefWidth="950.0"
           style="-fx-background-color: linear-gradient(to bottom right, #1a1a2e, #16213e, #0f3460);"
           xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="appli.accueil.LoginController">


    <VBox alignment="CENTER" maxWidth="440.0" spacing="0.0"
          style="-fx-background-color: rgba(255, 255, 255, 0.06); -fx-background-radius: 20; -fx-border-color: rgba(0, 212, 255, 0.25); -fx-border-width: 1; -fx-border-radius: 20; -fx-padding: 50 45 45 45;">
        <effect>
            <DropShadow color="rgba(0, 0, 0, 0.5)" radius="30" spread="0.1" />
        </effect>

        <!-- En-tête -->
        <VBox alignment="CENTER" spacing="8.0" style="-fx-padding: 0 0 35 0;">
            <Label style="-fx-font-size: 48px;" text="🔐" />
            <Label style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-font-family: 'Segoe UI Semibold';"
                   text="LPRS Manager" textFill="#00d4ff">
                <effect>
                    <DropShadow color="#00d4ff" radius="8" spread="0.2" />
                </effect>
            </Label>
            <Label style="-fx-font-size: 13px; -fx-font-family: 'Segoe UI';"
                   text="Connexion à votre espace" textFill="#95a5a6" />
        </VBox>

        <!-- Champ Email -->
        <VBox spacing="6.0" style="-fx-padding: 0 0 18 0;">
            <Label style="-fx-font-size: 12px; -fx-font-weight: bold;" text="Adresse email" textFill="#b0bec5" />
            <TextField fx:id="email" promptText="exemple@email.com"
                       style="-fx-background-color: rgba(255, 255, 255, 0.08); -fx-text-fill: white; -fx-prompt-text-fill: #546e7a; -fx-background-radius: 10; -fx-border-color: rgba(255, 255, 255, 0.15); -fx-border-radius: 10; -fx-padding: 12 15; -fx-font-size: 13px;" />
        </VBox>

        <!-- Champ Mot de passe -->
        <VBox spacing="6.0" style="-fx-padding: 0 0 8 0;">
            <Label style="-fx-font-size: 12px; -fx-font-weight: bold;" text="Mot de passe" textFill="#b0bec5" />
            <PasswordField fx:id="mdp" promptText="••••••••••"
                           style="-fx-background-color: rgba(255, 255, 255, 0.08); -fx-text-fill: white; -fx-prompt-text-fill: #546e7a; -fx-background-radius: 10; -fx-border-color: rgba(255, 255, 255, 0.15); -fx-border-radius: 10; -fx-padding: 12 15; -fx-font-size: 13px;" />
        </VBox>

        <!-- Mot de passe oublié -->
        <HBox alignment="CENTER_RIGHT" style="-fx-padding: 0 0 20 0;">
            <Button fx:id="oubliemdp" text="Mot de passe oublié ?"
                    style="-fx-background-color: transparent; -fx-text-fill: #00d4ff; -fx-font-size: 11px; -fx-cursor: hand; -fx-padding: 4 0;" />
        </HBox>

        <!-- Message erreur/succès -->
        <Label fx:id="erreur" maxWidth="350.0"
               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 0 0 15 0;"
               text="" textFill="RED" wrapText="true" />

        <!-- Bouton Connexion -->
        <Button fx:id="connexion" maxWidth="Infinity" text="Se connecter"
                style="-fx-background-color: linear-gradient(to right, #00d4ff, #0099cc); -fx-text-fill: #1a1a2e; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 10; -fx-padding: 13 0; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0, 212, 255, 0.4), 15, 0, 0, 3);" />

        <!-- Séparateur -->
        <HBox alignment="CENTER" spacing="10.0" style="-fx-padding: 25 0 20 0;">
            <Region HBox.hgrow="ALWAYS" style="-fx-background-color: rgba(255, 255, 255, 0.15); -fx-pref-height: 1;" />
            <Label style="-fx-font-size: 11px;" text="ou" textFill="#546e7a" />
            <Region HBox.hgrow="ALWAYS" style="-fx-background-color: rgba(255, 255, 255, 0.15); -fx-pref-height: 1;" />
        </HBox>

        <!-- Lien Inscription -->
        <HBox alignment="CENTER" spacing="5.0">
            <Label style="-fx-font-size: 12px;" text="Pas encore de compte ?" textFill="#95a5a6" />
            <Button fx:id="inscription" text="S'inscrire"
                    style="-fx-background-color: transparent; -fx-text-fill: #00d4ff; -fx-font-weight: bold; -fx-font-size: 12px; -fx-cursor: hand; -fx-padding: 0; -fx-underline: true;" />
        </HBox>
    </VBox>

</StackPane>
