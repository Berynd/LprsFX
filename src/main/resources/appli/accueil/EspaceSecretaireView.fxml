<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="650.0" prefWidth="900.0"
            style="-fx-background-color: #F5F6FA;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="appli.accueil.EspaceSecretaireController">

    <!-- HEADER -->
    <HBox fx:id="headerBar"
          prefHeight="90.0"
          style="-fx-background-color: linear-gradient(to right, #2980B9, #6DD5FA);
                 -fx-alignment: center;"
          AnchorPane.leftAnchor="0"
          AnchorPane.rightAnchor="0"
          AnchorPane.topAnchor="0">

        <Label text="Espace Secrétaire"
               textFill="WHITE"
               style="-fx-font-size: 24px; -fx-font-weight: bold;" />
    </HBox>

    <!-- MENU LATÉRAL -->
    <VBox fx:id="menuLateral"
          prefWidth="180.0"
          style="-fx-background-color: #2C3E50; -fx-padding: 10px;"
          AnchorPane.topAnchor="90.0"
          AnchorPane.bottomAnchor="0">

        <Button fx:id="carteCreeEtudiant"
                text="Créer étudiant"
                onMouseClicked="#handleCreerEtudiant"
                style="-fx-background-color: transparent;
                       -fx-text-fill: white;
                       -fx-padding: 12px;
                       -fx-font-size: 14px;" />

        <Button fx:id="carteCreeDossierInscription"
                text="Créer dossier"
                onMouseClicked="#handleCreerUnDossierInscription"
                style="-fx-background-color: transparent;
                       -fx-text-fill: white;
                       -fx-padding: 12px;
                       -fx-font-size: 14px;" />

        <Button fx:id="carteListeEtudiants"
                text="Liste étudiants"
                onMouseClicked="#handleListeDesEtudiants"
                style="-fx-background-color: transparent;
                       -fx-text-fill: white;
                       -fx-padding: 12px;
                       -fx-font-size: 14px;" />

        <Button fx:id="carteListeDossiers"
                text="Liste dossiers"
                onMouseClicked="#handleListeDesDossiers"
                style="-fx-background-color: transparent;
                       -fx-text-fill: white;
                       -fx-padding: 12px;
                       -fx-font-size: 14px;" />

        <Button text="Retour"
                onAction="#handleRetour"
                style="-fx-background-color: #E74C3C;
                       -fx-text-fill: white;
                       -fx-padding: 12px;
                       -fx-font-size: 14px;
                       -fx-background-radius: 8px;
                       -fx-margin-top: 20px;" />
    </VBox>

    <!-- CONTENU CENTRAL -->
    <VBox fx:id="contenuCentral"
          spacing="20"
          AnchorPane.leftAnchor="200.0"
          AnchorPane.rightAnchor="20.0"
          AnchorPane.topAnchor="100.0"
          AnchorPane.bottomAnchor="20.0">

        <!-- STATISTIQUES -->
        <HBox spacing="20">

            <!-- Étudiants acceptés -->
            <VBox style="-fx-background-color: white;
                        -fx-padding: 15px;
                        -fx-background-radius: 12px;
                        -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 8, 0, 0, 2);">
                <Label text="Étudiants acceptés"
                       style="-fx-font-weight: bold; -fx-text-fill: #27AE60;" />
                <Label fx:id="lblNbAccepte"
                       text="0"
                       style="-fx-font-size: 18px; -fx-text-fill: #27AE60;" />
            </VBox>

            <!-- Étudiants refusés -->
            <VBox style="-fx-background-color: white;
                        -fx-padding: 15px;
                        -fx-background-radius: 12px;
                        -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 8, 0, 0, 2);">
                <Label text="Étudiants refusés"
                       style="-fx-font-weight: bold; -fx-text-fill: #E74C3C;" />
                <Label fx:id="lblNbRefuse"
                       text="0"
                       style="-fx-font-size: 18px; -fx-text-fill: #E74C3C;" />
            </VBox>

            <!-- Étudiants en attente -->
            <VBox style="-fx-background-color: white;
                        -fx-padding: 15px;
                        -fx-background-radius: 12px;
                        -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 8, 0, 0, 2);">
                <Label text="Étudiants en attente"
                       style="-fx-font-weight: bold; -fx-text-fill: #2C3E50;" />
                <Label fx:id="lblNbEtudiants"
                       text="0"
                       style="-fx-font-size: 18px; -fx-text-fill: #2980B9;" />
            </VBox>

            <!-- Dossiers -->
            <VBox style="-fx-background-color: white;
                        -fx-padding: 15px;
                        -fx-background-radius: 12px;
                        -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 8, 0, 0, 2);">
                <Label text="Total dossiers"
                       style="-fx-font-weight: bold; -fx-text-fill: #2C3E50;" />
                <Label fx:id="lblNbDossier"
                       text="0"
                       style="-fx-font-size: 18px; -fx-text-fill: #E67E22;" />
            </VBox>

        </HBox>

        <!-- NOTIFICATIONS -->
        <VBox style="-fx-background-color: white;
                    -fx-padding: 15px;
                    -fx-background-radius: 12px;
                    -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 8, 0, 0, 2);">
            <Label text="Notifications"
                   style="-fx-font-weight: bold; -fx-text-fill: #2C3E50;" />
            <Label fx:id="lblNotification"
                   text="Aucune"
                   style="-fx-font-size: 14px;" />
        </VBox>

    </VBox>

</AnchorPane>