<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="650.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="appli.accueil.FicheEtudianteController">

    <top>
        <VBox style="-fx-background-color: #16a085; -fx-padding: 20;">
            <HBox alignment="CENTER_LEFT" spacing="15.0">
                <Button fx:id="retourAccueilBtn" text="← Accueil" onAction="#handleRetour"
                        style="-fx-background-color: #1abc9c; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" />
                <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                    <Label text="Gestion des Étudiants" textFill="WHITE">
                        <font><Font name="Arial Bold" size="24.0" /></font>
                    </Label>
                    <Label text="Créer et gérer les fiches étudiantes" textFill="#ecf0f1">
                        <font><Font name="Arial" size="12.0" /></font>
                    </Label>
                </VBox>
                <Button text="📋 Dossiers d'Inscription" onAction="#handleDossiers"
                        style="-fx-background-color: #e67e22; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 8 15;" />
            </HBox>
        </VBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.32">

            <!-- Formulaire -->
            <VBox spacing="12.0" style="-fx-background-color: #ecf0f1;">
                <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>

                <Label text="Informations de l'étudiant" style="-fx-font-weight: bold; -fx-font-size: 14px;" />

                <VBox spacing="4.0">
                    <Label text="Nom *" />
                    <TextField fx:id="nomTextField" promptText="Nom de famille" />
                </VBox>
                <VBox spacing="4.0">
                    <Label text="Prénom *" />
                    <TextField fx:id="prenomTextField" promptText="Prénom" />
                </VBox>
                <VBox spacing="4.0">
                    <Label text="Email *" />
                    <TextField fx:id="emailTextField" promptText="email@exemple.fr" />
                </VBox>
                <VBox spacing="4.0">
                    <Label text="Téléphone" />
                    <TextField fx:id="telephoneTextField" promptText="06 00 00 00 00" />
                </VBox>
                <VBox spacing="4.0">
                    <Label text="Adresse" />
                    <TextArea fx:id="adresseArea" prefRowCount="2" promptText="Adresse complète" wrapText="true" />
                </VBox>
                <VBox spacing="4.0">
                    <Label text="Dernier diplôme" />
                    <TextField fx:id="diplomeTextField" promptText="Ex: Baccalauréat, BTS..." />
                </VBox>

                <Label fx:id="messageLabel" wrapText="true">
                    <font><Font name="Arial Bold" size="11.0" /></font>
                </Label>

                <HBox spacing="8.0">
                    <Button fx:id="ajouterBtn" text="Ajouter" onAction="#handleAjouter"
                            style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;" prefWidth="90.0" />
                    <Button fx:id="modifierBtn" text="Modifier" onAction="#handleModifier"
                            style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold;" prefWidth="90.0" disable="true" />
                    <Button fx:id="annulerBtn" text="Annuler" onAction="#handleAnnuler"
                            style="-fx-background-color: #95a5a6; -fx-text-fill: white;" prefWidth="80.0" />
                </HBox>

                <Separator />
                <Label text="Rechercher" style="-fx-font-weight: bold;" />
                <TextField fx:id="rechercheTextField" promptText="Rechercher par nom, prénom, email..." onKeyReleased="#handleRecherche" />
            </VBox>

            <!-- Table -->
            <VBox spacing="10.0">
                <padding><Insets bottom="20.0" left="10.0" right="20.0" top="20.0" /></padding>

                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <Label text="Liste des étudiants" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
                    <Label fx:id="compteurLabel" text="(0 étudiant)" style="-fx-text-fill: #7f8c8d;" />
                </HBox>

                <TableView fx:id="etudiantTableView" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="idColumn" text="ID" prefWidth="45.0" />
                        <TableColumn fx:id="nomColumn" text="Nom" prefWidth="120.0" />
                        <TableColumn fx:id="prenomColumn" text="Prénom" prefWidth="120.0" />
                        <TableColumn fx:id="emailColumn" text="Email" prefWidth="180.0" />
                        <TableColumn fx:id="telephoneColumn" text="Téléphone" prefWidth="110.0" />
                        <TableColumn fx:id="actionsColumn" text="Actions" prefWidth="100.0" />
                    </columns>
                </TableView>

                <HBox spacing="10.0" alignment="CENTER_RIGHT">
                    <Button text="Actualiser" onAction="#handleActualiser"
                            style="-fx-background-color: #3498db; -fx-text-fill: white;" />
                    <Button fx:id="supprimerBtn" text="Supprimer" onAction="#handleSupprimer"
                            style="-fx-background-color: #e74c3c; -fx-text-fill: white;" disable="true" />
                </HBox>
            </VBox>

        </SplitPane>
    </center>

    <bottom>
        <HBox alignment="CENTER" style="-fx-background-color: #34495e; -fx-padding: 10;">
            <Label fx:id="statutLabel" text="Prêt" textFill="WHITE">
                <font><Font name="Arial" size="11.0" /></font>
            </Label>
        </HBox>
    </bottom>

</BorderPane>
