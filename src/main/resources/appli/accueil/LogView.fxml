<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="appli.accueil.LogController"
            prefWidth="1000" prefHeight="600">

    <children>

        <VBox spacing="10" AnchorPane.topAnchor="10" AnchorPane.bottomAnchor="10"
              AnchorPane.leftAnchor="10" AnchorPane.rightAnchor="10">

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Button text="← Retour" onAction="#handleRetour"
                        style="-fx-background-color: #7f8c8d; -fx-text-fill: white;"/>
                <Label text="Logs"
                       style="-fx-font-size: 20px; -fx-font-weight: bold;" />
            </HBox>

            <TableView fx:id="logTable" VBox.vgrow="ALWAYS">

                <columns>
                    <TableColumn text="ID" fx:id="idColumn" prefWidth="50"/>
                    <TableColumn text="Date / Heure" fx:id="heureColumn" prefWidth="160"/>
                    <TableColumn text="Utilisateur" fx:id="userColumn" prefWidth="160"/>
                    <TableColumn text="Message" fx:id="messageColumn" prefWidth="300"/>
                    <TableColumn text="Action" fx:id="actionColumn" prefWidth="120"/>
                    <TableColumn text="Page" fx:id="pageColumn" prefWidth="150"/>
                </columns>

            </TableView>

        </VBox>

    </children>

</AnchorPane>