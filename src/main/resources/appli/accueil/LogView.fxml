<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="appli.accueil.LogView"
            prefWidth="1000" prefHeight="600">

    <children>

        <VBox spacing="10" AnchorPane.topAnchor="10" AnchorPane.bottomAnchor="10"
              AnchorPane.leftAnchor="10" AnchorPane.rightAnchor="10">

            <Label text="Logs"
                   style="-fx-font-size: 20px; -fx-font-weight: bold;" />

            <TableView fx:id="logTable" VBox.vgrow="ALWAYS">

                <columns>
                    <TableColumn text="ID" fx:id="idColumn"/>
                    <TableColumn text="Heure" fx:id="heureColumn"/>
                    <TableColumn text="Utilisateur" fx:id="userColumn"/>
                    <TableColumn text="Message" fx:id="messageColumn"/>
                    <TableColumn text="Action" fx:id="actionColumn"/>
                    <TableColumn text="Page" fx:id="pageColumn"/>
                </columns>

            </TableView>

        </VBox>

    </children>

</AnchorPane>