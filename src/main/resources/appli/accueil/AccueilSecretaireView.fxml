<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="750.0" prefWidth="1000.0"
            style="-fx-background-color: linear-gradient(to bottom right, #1a1a2e, #16213e, #0f3460);"
            xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="appli.accueil.AccueilSecretaireController">

    <!-- Header -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20.0"
              style="-fx-background-color: rgba(255,255,255,0.05); -fx-padding: 15 30; -fx-border-color: rgba(255,255,255,0.1); -fx-border-width: 0 0 1 0;">
            <Label style="-fx-font-weight: bold; -fx-font-size: 20px; -fx-font-family: 'Segoe UI Semibold';"
                   text="LPRS Manager" textFill="#00d4ff" />
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="utilisateurLabel" style="-fx-font-size: 12px;" text="👤 ..." textFill="WHITE">
                <font><Font name="Arial" size="12.0" /></font>
            </Label>
            <Button onAction="#handleDeconnexion"
                    style="-fx-background-color: rgba(231,76,60,0.2); -fx-text-fill: #e74c3c; -fx-border-color: #e74c3c; -fx-border-width: 1; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8 15; -fx-font-weight: bold; -fx-cursor: hand;"
                    text="Se déconnecter" />
        </HBox>
    </top>

    <!-- Contenu -->
    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                    style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;">
            <VBox alignment="TOP_CENTER" spacing="35.0" style="-fx-padding: 45;">

                <!-- Bienvenue -->
                <VBox alignment="CENTER" spacing="6.0">
                    <Label fx:id="bienvenuLabel" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-font-family: 'Segoe UI Light';" textFill="WHITE">
                        <effect><DropShadow color="#00d4ff" radius="8" spread="0.2"/></effect>
                    </Label>
                    <Label style="-fx-font-size: 14px;" text="Espace Secrétaire — Gestion administrative" textFill="#95a5a6" />
                </VBox>

                <!-- Statistiques -->
                <VBox spacing="12.0">
                    <Label style="-fx-font-size: 13px; -fx-font-weight: bold;" text="📊  Statistiques des dossiers" textFill="#00d4ff" />
                    <HBox spacing="20.0">
                        <VBox alignment="CENTER" spacing="8.0" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: rgba(255,255,255,0.07); -fx-background-radius: 15; -fx-border-color: rgba(46,204,113,0.4); -fx-border-width: 1; -fx-border-radius: 15; -fx-padding: 22;">
                            <effect><DropShadow color="rgba(0,0,0,0.3)" radius="10" spread="0.05"/></effect>
                            <Label style="-fx-font-size: 26px;" text="✅" />
                            <Label fx:id="lblNbAccepte" style="-fx-font-size: 30px; -fx-font-weight: bold;" text="0" textFill="#2ecc71" />
                            <Label style="-fx-font-size: 11px;" text="Acceptés" textFill="#95a5a6" />
                        </VBox>
                        <VBox alignment="CENTER" spacing="8.0" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: rgba(255,255,255,0.07); -fx-background-radius: 15; -fx-border-color: rgba(231,76,60,0.4); -fx-border-width: 1; -fx-border-radius: 15; -fx-padding: 22;">
                            <effect><DropShadow color="rgba(0,0,0,0.3)" radius="10" spread="0.05"/></effect>
                            <Label style="-fx-font-size: 26px;" text="❌" />
                            <Label fx:id="lblNbRefuse" style="-fx-font-size: 30px; -fx-font-weight: bold;" text="0" textFill="#e74c3c" />
                            <Label style="-fx-font-size: 11px;" text="Refusés" textFill="#95a5a6" />
                        </VBox>
                        <VBox alignment="CENTER" spacing="8.0" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: rgba(255,255,255,0.07); -fx-background-radius: 15; -fx-border-color: rgba(52,152,219,0.4); -fx-border-width: 1; -fx-border-radius: 15; -fx-padding: 22;">
                            <effect><DropShadow color="rgba(0,0,0,0.3)" radius="10" spread="0.05"/></effect>
                            <Label style="-fx-font-size: 26px;" text="⏳" />
                            <Label fx:id="lblNbAttente" style="-fx-font-size: 30px; -fx-font-weight: bold;" text="0" textFill="#3498db" />
                            <Label style="-fx-font-size: 11px;" text="En attente" textFill="#95a5a6" />
                        </VBox>
                        <VBox alignment="CENTER" spacing="8.0" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: rgba(255,255,255,0.07); -fx-background-radius: 15; -fx-border-color: rgba(230,126,34,0.4); -fx-border-width: 1; -fx-border-radius: 15; -fx-padding: 22;">
                            <effect><DropShadow color="rgba(0,0,0,0.3)" radius="10" spread="0.05"/></effect>
                            <Label style="-fx-font-size: 26px;" text="📁" />
                            <Label fx:id="lblNbTotal" style="-fx-font-size: 30px; -fx-font-weight: bold;" text="0" textFill="#e67e22" />
                            <Label style="-fx-font-size: 11px;" text="Total dossiers" textFill="#95a5a6" />
                        </VBox>
                    </HBox>
                </VBox>

                <!-- Cartes navigation -->
                <VBox spacing="12.0">
                    <Label style="-fx-font-size: 13px; -fx-font-weight: bold;" text="🗂  Navigation rapide" textFill="#00d4ff" />
                    <GridPane alignment="CENTER" hgap="25.0" vgap="25.0">
                        <VBox fx:id="carteFicheEtudiante" alignment="CENTER" onMouseClicked="#handleFicheEtudiante"
                              prefHeight="180.0" prefWidth="210.0" spacing="12.0"
                              style="-fx-background-color: rgba(255,255,255,0.08); -fx-background-radius: 15; -fx-padding: 28; -fx-border-color: rgba(52,152,219,0.3); -fx-border-width: 1; -fx-border-radius: 15; -fx-cursor: hand; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.3),15,0,0,5);"
                              GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label style="-fx-font-size: 42px;" text="🎓" />
                            <Label style="-fx-font-size: 15px; -fx-font-weight: bold;" text="Fiches Étudiantes" textFill="WHITE" />
                            <Label style="-fx-font-size: 11px; -fx-text-alignment: center;" text="Gérer les fiches étudiantes" textFill="#95a5a6" wrapText="true" />
                        </VBox>
                        <VBox fx:id="carteDossiers" alignment="CENTER" onMouseClicked="#handleDossiers"
                              prefHeight="180.0" prefWidth="210.0" spacing="12.0"
                              style="-fx-background-color: rgba(255,255,255,0.08); -fx-background-radius: 15; -fx-padding: 28; -fx-border-color: rgba(230,126,34,0.3); -fx-border-width: 1; -fx-border-radius: 15; -fx-cursor: hand; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.3),15,0,0,5);"
                              GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <Label style="-fx-font-size: 42px;" text="📄" />
                            <Label style="-fx-font-size: 15px; -fx-font-weight: bold;" text="Dossiers Inscription" textFill="WHITE" />
                            <Label style="-fx-font-size: 11px; -fx-text-alignment: center;" text="Suivi des dossiers" textFill="#95a5a6" wrapText="true" />
                        </VBox>
                        <VBox fx:id="carteFilieres" alignment="CENTER" onMouseClicked="#handleFilieres"
                              prefHeight="180.0" prefWidth="210.0" spacing="12.0"
                              style="-fx-background-color: rgba(255,255,255,0.08); -fx-background-radius: 15; -fx-padding: 28; -fx-border-color: rgba(39,174,96,0.3); -fx-border-width: 1; -fx-border-radius: 15; -fx-cursor: hand; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.3),15,0,0,5);"
                              GridPane.columnIndex="2" GridPane.rowIndex="0">
                            <Label style="-fx-font-size: 42px;" text="🏫" />
                            <Label style="-fx-font-size: 15px; -fx-font-weight: bold;" text="Filières" textFill="WHITE" />
                            <Label style="-fx-font-size: 11px; -fx-text-alignment: center;" text="Gérer les filières" textFill="#95a5a6" wrapText="true" />
                        </VBox>
                        <VBox fx:id="carteEspaceSecretaire" alignment="CENTER" onMouseClicked="#handleEspaceSecretaire"
                              prefHeight="180.0" prefWidth="210.0" spacing="12.0"
                              style="-fx-background-color: rgba(255,255,255,0.08); -fx-background-radius: 15; -fx-padding: 28; -fx-border-color: rgba(0,212,255,0.3); -fx-border-width: 1; -fx-border-radius: 15; -fx-cursor: hand; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.3),15,0,0,5);"
                              GridPane.columnIndex="3" GridPane.rowIndex="0">
                            <Label style="-fx-font-size: 42px;" text="📊" />
                            <Label style="-fx-font-size: 15px; -fx-font-weight: bold;" text="Mon Dashboard" textFill="WHITE" />
                            <Label style="-fx-font-size: 11px; -fx-text-alignment: center;" text="Statistiques détaillées" textFill="#95a5a6" wrapText="true" />
                        </VBox>
                    </GridPane>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

    <!-- Footer -->
    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="30.0"
              style="-fx-background-color: rgba(0,0,0,0.3); -fx-padding: 15 30; -fx-border-color: rgba(255,255,255,0.1); -fx-border-width: 1 0 0 0;">
            <Label style="-fx-font-size: 10px;" text="© 2026 LPRS Manager" textFill="#546e7a" />
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="dateHeureLabel" style="-fx-font-size: 11px;" text="📅 ..." textFill="#95a5a6" />
        </HBox>
    </bottom>

</BorderPane>
